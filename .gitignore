# Git ignore for AI News Platform
# =================================

# Build outputs
backend/build/
backend/cmake-build-*/
*.o
*.a
*.so
*.exe

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Flutter build outputs
flutter_app/build/
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/pubspec.lock

# Environment / secrets (NEVER commit these)
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# IDE
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Logs
logs/
*.log
*.log.*

# Docker volumes (local only)
postgres_data/
redis_data/

# Node (if any tooling)
node_modules/

# OS
desktop.ini
